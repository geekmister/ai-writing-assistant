{
  "name": "ai-writing-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "AI 写作助手 - 基于 TipTap + Vue 3 的智能写作工具，支持选区重写、风格库、素材库",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,css,json}\"",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@tiptap/extension-bubble-menu": "^2.6.0",
    "@tiptap/extension-character-count": "^2.6.0",
    "@tiptap/extension-placeholder": "^2.6.0",
    "@tiptap/pm": "^2.6.0",
    "@tiptap/starter-kit": "^2.6.0",
    "@tiptap/vue-3": "^2.6.0",
    "@vicons/ionicons5": "^0.12.0",
    "date-fns": "^3.6.0",
    "dexie": "^3.2.7",
    "dompurify": "^3.1.0",
    "jieba-wasm": "^2.4.0",
    "lodash-es": "^4.17.21",
    "markdown-it": "^14.1.0",
    "naive-ui": "^2.39.0",
    "pinia": "^2.2.0",
    "uuid": "^10.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.10.0",
    "@types/dompurify": "^3.0.5",
    "@types/lodash-es": "^4.17.12",
    "@types/markdown-it": "^14.1.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/tsconfig": "^0.6.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.27.0",
    "prettier": "^3.3.0",
    "typescript": "~5.5.0",
    "vite": "^5.4.0",
    "vue-tsc": "^2.1.0"
  }
}
